# Copie para .env.local (local) ou configure no painel do seu host (Vercel, etc.)

# Banco Postgres (Vercel Postgres / Neon) — OBRIGATÓRIO.
# No Vercel: adicione a integração de Postgres (injeta DATABASE_URL/POSTGRES_URL).
DATABASE_URL=

# Senha única de acesso. Se ficar vazia, o app abre sem login (modo local).
APP_PASSWORD=

# Segredo para assinar o cookie. Gere um valor longo e aleatório, por exemplo:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# IA do Coach (OpenAI) — opcional. Sem isso, o Coach usa só o motor de regras.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
