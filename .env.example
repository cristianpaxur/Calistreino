# Copie para .env.local (local) ou configure no painel do seu host (Vercel, etc.)

# ── Supabase (autenticação + dados) — OBRIGATÓRIO ──────────────────────
# Supabase → Project Settings → API.
# Chaves "public" (anon) vão para o navegador → precisam do prefixo NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role (secreta, só servidor) — usada por scripts/seed administrativos.
SUPABASE_SERVICE_ROLE_KEY=

# IA do Coach (OpenAI) — opcional. Sem isso, o Coach usa só o motor de regras.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Nota: a partir da 002, o login é por conta (Supabase Auth). APP_PASSWORD e
# AUTH_SECRET não são mais usados e podem ser removidos após o cutover.

# ── Stripe (monetização freemium 010) — opcional/human-gated ──────────
# Sem estas chaves, o app roda 100% no tier free (checkout indisponível).
# Requer também `npm i stripe` (não instalado nesta fatia de código).
# Stripe → Developers → API keys (use as de TESTE no dev).
STRIPE_SECRET_KEY=
# Stripe → Developers → Webhooks → assinatura do endpoint (ou `stripe listen`).
STRIPE_WEBHOOK_SECRET=
# Stripe → Products → Prices: IDs dos planos mensal e anual.
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
# URL pública do app (success_url/cancel_url/return_url do Stripe).
NEXT_PUBLIC_APP_URL=http://localhost:3000
